<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <AssemblyName>VideoBatchEncoder</AssemblyName>
    <RootNamespace>VideoBatchEncoder</RootNamespace>
    <AssemblyTitle>動画一括エンコードツール</AssemblyTitle>
    <AssemblyDescription>NVENC MP4一括変換ツール</AssemblyDescription>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
    <!-- アイコンを設定する場合: <ApplicationIcon>VideoBatchEncoder.ico</ApplicationIcon> -->
  </PropertyGroup>

</Project>
